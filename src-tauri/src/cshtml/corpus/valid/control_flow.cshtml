@model MyApp.Models.ListViewModel

@* @if / @else *@
@if (Model.Items.Any())
{
    <ul>
    @foreach (var item in Model.Items)
    {
        <li class="@(item.IsSelected ? "selected" : "")">
            @item.Name — @item.Price.ToString("C")
        </li>
    }
    </ul>
}
else
{
    <p>No items found.</p>
}

@* @switch *@
@switch (Model.Status)
{
    case "active":
        <span class="badge-green">Active</span>
        break;
    case "pending":
        <span class="badge-yellow">Pending</span>
        break;
    default:
        <span class="badge-gray">Unknown</span>
        break;
}

@* @for loop *@
@for (int i = 0; i < 3; i++)
{
    <p>Row @i</p>
}

@* @while *@
@{ int n = 0; }
@while (n < 2)
{
    <span>@n</span>
    n++;
}

@* @try / catch / finally *@
@try
{
    var x = Model.RiskyProp;
    <p>@x</p>
}
catch (Exception ex)
{
    <p class="error">@ex.Message</p>
}
finally
{
    @* cleanup *@
}

@* HTML inside C# block *@
@{
    var items = new[] { "a", "b", "c" };
    foreach (var s in items)
    {
        <span>@s</span>
    }
}
