@model object

@* Unicode: BMP and supplementary plane characters *@
@{
    // BMP: Japanese Hiragana
    string japanese = "こんにちは";
    // Supplementary: Math symbols (U+1D400 = 𝐀)
    string math = "𝐀𝐁𝐂";
    // Emoji (U+1F600 = 😀 — two UTF-16 code units)
    string emoji = "😀🎉🚀";
    // Right-to-left: Arabic
    string arabic = "مرحبا";
    // Zero-width joiner sequences
    string zwj = "👨‍💻";
}

<p lang="ja">@japanese</p>
<p>Math: @math</p>
<p>Emoji: @emoji</p>
<p dir="rtl" lang="ar">@arabic</p>
<p>Dev: @zwj</p>

@* Unicode in attribute values *@
<input placeholder="Buscar…" aria-label="Suche" />

@* Unicode identifiers in C# (valid per C# spec) *@
@{
    int café = 1;
    int naïve = 2;
}
<p>@café @naïve</p>
