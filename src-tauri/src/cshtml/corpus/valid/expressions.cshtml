@model MyApp.Models.UserViewModel

@* Implicit expressions *@
<p>Hello, @Model.Name!</p>
<p>Email: @Model.Email.ToLower()</p>
<p>Today: @DateTime.Now.ToString("yyyy-MM-dd")</p>

@* Explicit parenthesised expressions *@
<p>(@Model.FirstName + " " + @Model.LastName)</p>
<span>Count: @(Model.Items.Count * 2)</span>
<a href="/user/@(Model.Id)">Profile</a>

@* Escaped @ *@
<p>Contact us at support@@example.com</p>
<p>Email regex: ^[\w-]+@@[\w-]+\.[\w]+$</p>

@* Conditional expression *@
<p class="@(Model.IsActive ? "active" : "inactive")">Status</p>

@* Chained member access *@
<p>@Model.Address.City.ToUpper()</p>

@* Indexer access *@
<p>@Model.Tags[0]</p>
<p>@Model.Meta["description"]</p>
